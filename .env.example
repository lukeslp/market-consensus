# Foresight — Environment Variables
# Copy this file to .env and fill in your API keys

# === LLM Provider API Keys ===
# At minimum, 2-3 providers are needed for the swarm democracy to work.
# Premium tier (highest weight):
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# Mid tier:
XAI_API_KEY=xai-...

# Standard tier:
PERPLEXITY_API_KEY=pplx-...
MISTRAL_API_KEY=...
COHERE_API_KEY=...
HUGGINGFACE_API_KEY=hf_...

# === Application Settings ===
# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=false

# Database
DB_PATH=foresight.db

# Server
PORT=5062
HOST=0.0.0.0

# === Prediction Settings ===
# Include crypto assets in prediction cycles
INCLUDE_CRYPTO=true

# Maximum number of equity/crypto symbols per cycle
MAX_STOCKS=50
MAX_CRYPTO_SYMBOLS=50

# Cycle interval in seconds (default: 1800 = 30 minutes)
CYCLE_INTERVAL=1800
